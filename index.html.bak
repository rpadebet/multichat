// ══════════════════════════════════════════
// STATE
// ══════════════════════════════════════════
let conversations = {};
let currentChatId = null;
let isStreaming = false;
let attachedFiles = []; // {name, content, size} for inline attach (per-message)
let ragFiles = [];      // {name, content, size} for persistent RAG context
let lastSearchMeta = null; // {queries[], provider, results[], grouped[]} for the current in-flight response

// ══════════════════════════════════════════
// WEB SEARCH
// ══════════════════════════════════════════
const SEARCH_PROVIDERS = {
  tavily: {
    label: 'Tavily (AI-optimized)',
    keyName: 'key_search_tavily',
    costNote: '1,000 free searches/month · ~$0.001/search after · Best quality for AI · Free key at tavily.com (no credit card)'
  },
  serper: {
    label: 'Serper (Google results)',
    keyName: 'key_search_serper',
    costNote: '2,500 free on account creation · ~$0.001/search after · Google-quality results · Free key at serper.dev'
  }
};

function getSearchKey(provider) {
  const keyName = SEARCH_PROVIDERS[provider]?.keyName;
  return keyName ? (localStorage.getItem(keyName) || '') : '';
}

function saveSearchKey(value) {
  const provider = document.getElementById('ws-provider')?.value;
  if (!provider) return;
  const keyName = SEARCH_PROVIDERS[provider]?.keyName;
  if (!keyName) return;
  if (value.trim()) localStorage.setItem(keyName, value.trim());
  else localStorage.removeItem(keyName);
}

function saveWebSearchSettings() {
  const existing = JSON.parse(localStorage.getItem('mc_settings') || '{}');
  existing.webSearchEnabled = document.getElementById('ws-enabled')?.checked || false;
  existing.webSearchProvider = document.getElementById('ws-provider')?.value || 'tavily';
  existing.webSearchMode = document.getElementById('ws-mode')?.value || 'auto';
  localStorage.setItem('mc_settings', JSON.stringify(existing));
  updateSearchIndicator();
}

function loadWebSearchSettings() {
  try {
    const s = JSON.parse(localStorage.getItem('mc_settings') || '{}');
    const enabled = s.webSearchEnabled || false;
    const provider = s.webSearchProvider || 'tavily';
    const mode = s.webSearchMode || 'auto';

    const elEnabled = document.getElementById('ws-enabled');
    if (elEnabled) elEnabled.checked = enabled;

    const elProvider = document.getElementById('ws-provider');
    if (elProvider) elProvider.value = provider;

    const elMode = document.getElementById('ws-mode');
    if (elMode) elMode.value = mode;

    const cfg = document.getElementById('ws-config');
    if (cfg) cfg.style.display = enabled ? 'flex' : 'none';

    updateSearchKeyRow(provider);
    updateSearchCostNote(provider);

    // Restore saved key for current provider
    const keyName = SEARCH_PROVIDERS[provider]?.keyName;
    if (keyName) {
      const k = localStorage.getItem(keyName);
      const kInput = document.getElementById('ws-key-input');
      if (kInput && k) kInput.value = k;
    }

    updateSearchIndicator();
  } catch(e) {}
}

function onWebSearchToggle() {
  const enabled = document.getElementById('ws-enabled').checked;
  const cfg = document.getElementById('ws-config');
  if (cfg) cfg.style.display = enabled ? 'flex' : 'none';
  saveWebSearchSettings();
}

function onWebSearchProviderChange() {
  const provider = document.getElementById('ws-provider').value;
  updateSearchKeyRow(provider);
  updateSearchCostNote(provider);
  // Load saved key for newly selected provider
  const keyName = SEARCH_PROVIDERS[provider]?.keyName;
  const kInput = document.getElementById('ws-key-input');
  if (kInput) kInput.value = keyName ? (localStorage.getItem(keyName) || '') : '';
  saveWebSearchSettings();
}

function updateSearchKeyRow(provider) {
  const row = document.getElementById('ws-key-row');
  if (!row) return;
  row.style.display = SEARCH_PROVIDERS[provider]?.keyName ? 'block' : 'none';
}

function updateSearchCostNote(provider) {
  const note = document.getElementById('ws-cost-note');
  if (note) note.textContent = SEARCH_PROVIDERS[provider]?.costNote || '';
}

function updateSearchIndicator() {
  const ind = document.getElementById('search-indicator');
  if (!ind) return;
  const s = JSON.parse(localStorage.getItem('mc_settings') || '{}');
  if (s.webSearchEnabled) {
    const mode = s.webSearchMode === 'always' ? 'Always' : 'Auto';
    const prov = SEARCH_PROVIDERS[s.webSearchProvider || 'tavily'];
    ind.textContent = `🔍 ${mode} · ${prov?.label || ''}`;
    ind.style.display = 'inline-flex';
  } else {
    ind.style.display = 'none';
  }
}

// ── Typing indicator search status ──
function setTypingSearchStatus(query) {
  const row = document.getElementById('typing-row');
  if (!row) return;
  const body = row.querySelector('.msg-body');
  if (!body) return;
  if (query) {
    body.innerHTML = `<div class="msg-meta"><span class="msg-name">MultiChat</span></div>
      <div style="display:flex;align-items:center;gap:7px;font-size:12px;color:var(--text3);">
        <span style="font-size:15px;">🔍</span>
        <span>Searching: <em>${esc(query.slice(0, 70))}${query.length > 70 ? '…' : ''}</em></span>
      </div>`;
  } else {
    body.innerHTML = `<div class="msg-meta"><span class="msg-name">MultiChat</span></div>
      <div class="typing-ind"><div class="tdot"></div><div class="tdot"></div><div class="tdot"></div></div>`;
  }
}

// ── Search need detection ──
const SEARCH_PATTERNS = [
  /\b(today|yesterday|this week|this month|right now|currently|at the moment)\b/i,
  /\b(latest|newest|most recent|just released|just launched|just announced|recently announced)\b/i,
  /\b(current|live|real.?time|up.?to.?date|as of)\b/i,
  /\b(news|headline|breaking|update|trend|trending)\b/i,
  /\b(price of|cost of|how much is|stock price|bitcoin|crypto|exchange rate)\b/i,
  /\b(weather|temperature|forecast|rain|snow|humidity) (in|at|for)\b/i,
  /\b(who is|who are|who was|who were|who won|who leads|who runs)\b/i,
  /\b(what is the current|what are the latest|what was the recent|what is the new)\b/i,
  /\b(when (is|was|did|will|does))\b/i,
  /\b(score|result|winner|championship|tournament|election|vote|poll|standings)\b/i,
  /\b202[3-9]|203[0-9]\b/,
  /\b(release date|launch date|out now|available now|coming out)\b/i,
  /\b(CEO|CTO|president|prime minister|chancellor|secretary of)\b/i,
  /\b(version \d|v\d+\.\d+|changelog|patch notes)\b/i,
  /\b(died|death of|passed away|born in|age of|how old is)\b/i,
  /\b(founded|acquired|merger|IPO|valuation|funding round|series [A-E])\b/i,
  /\b(latest model|new model|just released model|best model|top model)\b/i,
];

function detectSearchNeeded(message) {
  const needed = SEARCH_PATTERNS.some(p => p.test(message));
  // Extract a focused search query:
  // 1. Strip conversational openers
  // 2. Take only the first sentence/clause (before . or ?)
  // 3. Remove trailing compound clauses ("and what is...", "and how does...")
  // 4. Trim to 90 chars so search engines get a clean, focused query
  let query = message
    .replace(/^(can you |could you |please |tell me |i want to know |find out |look up |search for |what is the |what are the |what is |what are )/i, '')
    .split(/[.!?]/)[0]                                             // first sentence only
    .replace(/\s+(and what|and how|and why|and when|and where|and compare|and give|and also)\b.*/i, '') // drop compound clauses
    .replace(/\?+$/, '')
    .trim()
    .slice(0, 90);
  // Append current year for time-sensitive queries without an explicit year
  if (needed && !/\b20\d\d\b/.test(query)) {
    query = query + ' ' + new Date().getFullYear();
  }
  return { needed, query: query.trim() };
}

// ── Provider search implementations ──
async function searchTavily(query, apiKey) {
  const resp = await fetch('https://api.tavily.com/search', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ api_key: apiKey, query, search_depth: 'advanced', max_results: 5 })
  });
  if (!resp.ok) {
    const err = await resp.json().catch(() => ({}));
    throw new Error(err?.detail || err?.message || `Tavily HTTP ${resp.status}`);
  }
  const data = await resp.json();
  const results = (data.results || []).map(r => ({
    title: r.title || '',
    url: r.url || '',
    snippet: (r.content || '').slice(0, 800)
  }));
  return results;
}

async function searchSerper(query, apiKey) {
  const resp = await fetch('https://google.serper.dev/search', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'X-API-KEY': apiKey },
    body: JSON.stringify({ q: query, num: 5 })
  });
  if (!resp.ok) throw new Error(`Serper HTTP ${resp.status}`);
  const data = await resp.json();
  const results = [];
  if (data.answerBox?.answer || data.answerBox?.snippet) {
    results.push({ title: 'Answer Box', url: data.answerBox?.link || '', snippet: data.answerBox.answer || data.answerBox.snippet });
  }
  (data.organic || []).slice(0, 5).forEach(r => results.push({ title: r.title || '', url: r.link || '', snippet: r.snippet || '' }));
  return results;
}

async function executeSearch(query, provider) {
  provider = provider || 'tavily';
  const apiKey = getSearchKey(provider);
  if (!apiKey) throw new Error(`No API key for ${SEARCH_PROVIDERS[provider]?.label || provider}. Add it in Settings → Web Search.`);
  if (provider === 'tavily') return searchTavily(query, apiKey);
  if (provider === 'serper') return searchSerper(query, apiKey);
  throw new Error(`Unknown search provider: ${provider}`);
}

// ── LLM-guided search query planner ──
// Asks the active LLM to decompose the user's message into optimal search queries.
// Returns { needs_search: bool, search_queries: string[] }
// Falls back to regex heuristic if the LLM call fails for any reason.
async function planSearchQueries(userMessage, provider, model, apiKey) {
  const yr = new Date().getFullYear();
  const systemPrompt = `You are a web search query planner. Today: ${new Date().toLocaleDateString('en-US', {year:'numeric',month:'long',day:'numeric'})}.

Your job: read the user's message and output a JSON object deciding whether web search is needed and what queries to run.

needs_search = true for: current prices/stocks/crypto, live data, news from 2024 onwards, recent product releases, current events, status of living people/companies.
needs_search = false for: definitions, explanations, math, coding, creative tasks, history before 2024.

Query rules:
- One query per DISTINCT information need — if user asks about 2 separate topics, output 2 queries
- Never combine unrelated topics into one query
- 4-8 words each, include ${yr} for time-sensitive data
- Maximum 3 queries

You MUST output ONLY a raw JSON object. No markdown. No explanation. No code fences. Just the JSON:
{"needs_search": true, "search_queries": ["query 1", "query 2"]}`;

  try {
    const providerUrl = PROVIDERS[provider]?.url;
    if (!providerUrl) throw new Error('Unknown provider');
    const resp = await fetch(providerUrl + '/chat/completions', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${apiKey}` },
      body: JSON.stringify({
        model,
        messages: [
          { role: 'system', content: systemPrompt },
          { role: 'user', content: userMessage.slice(0, 600) }
        ],
        max_tokens: 200,
        temperature: 0.1,
        stream: false,
        ...(provider === 'openrouter' && { transforms: [], provider: { ignore: ['Amazon Bedrock'] } })
      })
    });
    if (!resp.ok) throw new Error(`Planner HTTP ${resp.status}`);
    const data = await resp.json();
    let raw = data.choices?.[0]?.message?.content || '';
    // Strip markdown code fences if present
    raw = raw.replace(/^```(?:json)?\s*/i, '').replace(/\s*```\s*$/, '').trim();
    const plan = JSON.parse(raw);
    if (typeof plan.needs_search !== 'boolean' || !Array.isArray(plan.search_queries)) throw new Error('Bad plan format');
    return { needs_search: plan.needs_search, search_queries: plan.search_queries.filter(q => q?.trim()).slice(0, 3) };
  } catch(e) {
    // Fallback: use regex heuristic
    const fallback = detectSearchNeeded(userMessage);
    return { needs_search: fallback.needed, search_queries: fallback.needed ? [fallback.query] : [] };
  }
}

function formatSearchContext(queries, results) {
  if (!results?.length) return '';
  const date = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
  const queryList = Array.isArray(queries) ? queries : [queries];
  let ctx = `[Web Search Results — retrieved: ${date}]\n`;
  ctx += `[Queries: ${queryList.map(q => `"${q}"`).join(', ')}]\n\n`;
  let idx = 1;
  results.forEach(group => {
    if (group.query && queryList.length > 1) ctx += `--- Results for: "${group.query}" ---\n`;
    (group.items || [group]).forEach(r => {
      ctx += r.url
        ? `[${idx}] ${r.title}\nURL: ${r.url}\n${r.snippet}\n\n`
        : `[${idx}] ${r.title}\n${r.snippet}\n\n`;
      idx++;
    });
  });
  ctx += `[End of search results.
INSTRUCTIONS:
- Summarize the news and information from the titles and snippets above — headlines and titles ARE facts you can report.
- Cite the source number [N] after each piece of information drawn from that source.
- You may draw reasonable inferences from a headline (e.g. if the title says "X happened", report that X happened).
- IMPORTANT: If any snippet contains placeholder text like [PERSON_NAME], [ADDRESS], or [LOCATION], resolve these using the search queries listed above and the article titles — the queries name the specific people and places being discussed. Always use the actual names in your response, never repeat placeholder text.
- Do NOT invent specific details (exact numbers, direct quotes, casualty figures) that do not appear anywhere in the snippets.
- If something is not mentioned at all in any snippet or title, say so rather than guessing.
- Do NOT assign citation numbers randomly — only cite [N] if that source's title or snippet actually mentions the fact.]`;
  return ctx;
}

function renderSearchPanel(searchMeta) {
  if (!searchMeta?.results?.length) return '';
  const { provider, results } = searchMeta;
  // Handle both new format (queries array) and old history format (query string)
  const queries = searchMeta.queries || (searchMeta.query ? [searchMeta.query] : []);
  const provLabel = SEARCH_PROVIDERS[provider]?.label || provider;
  const queryList = Array.isArray(queries) ? queries : [queries].filter(Boolean);
  const queryDisplay = queryList.length > 1
    ? queryList.map(q => `"${q}"`).join(' · ')
    : `"${queryList[0] || ''}"`;

  const sourcesHTML = results.map((r, i) => {
    const urlHtml = r.url
      ? `<a class="search-source-url" href="${esc(r.url)}" target="_blank" rel="noopener noreferrer">${esc(r.url.replace(/^https?:\/\//,'').slice(0,70))}</a>`
      : '';
    const snippet = (r.snippet || '').slice(0, 220);
    return `<div class="search-source">
      <div class="search-source-title">${esc(r.title || `Source ${i+1}`)}</div>
      ${urlHtml}
      ${snippet ? `<div class="search-source-snippet">${esc(snippet)}${(r.snippet||'').length > 220 ? '…' : ''}</div>` : ''}
    </div>`;
  }).join('');

  const totalSources = results.length;
  const hdrQueryText = queryDisplay.length > 80 ? queryDisplay.slice(0, 80) + '…' : queryDisplay;
  return `<div class="search-block">
    <div class="search-hdr" onclick="toggleSearch(this)">
      <span class="search-chev">▶</span>
      <span class="search-hdr-query">🔍 Web search: ${esc(hdrQueryText)}</span>
      <span style="flex-shrink:0;font-size:11px;white-space:nowrap;margin-left:6px;">${totalSources} source${totalSources===1?'':'s'} · ${esc(provLabel)}</span>
    </div>
    <div class="search-body">${sourcesHTML}</div>
  </div>`;
}

function toggleSearch(hdr) {
  hdr.querySelector('.search-chev').classList.toggle('open');
  hdr.nextElementSibling.classList.toggle('vis');
}

// ══════════════════════════════════════════
// INIT
// ══════════════════════════════════════════
window.onload = async () => {
  loadKeys();
  loadChats();
  loadSettings();
  await populateModels('openrouter');
  updateProviderBadge('openrouter');
  // Select DeepSeek V3.2 as default model if present
  const modelSel = document.getElementById('model-sel');
  const dsOpt = Array.from(modelSel.options).find(o => o.value.includes('deepseek-v3.2') || o.value.includes('deepseek/deepseek-v3.2'));
  if (dsOpt) modelSel.value = dsOpt.value;
  updatePricePill();
  loadTheme();
  document.getElementById('model-search').addEventListener('input', function() {
    const q = this.value.toLowerCase();
    Array.from(modelSel.options).forEach(opt => {
      opt.style.display = !q || opt.text.toLowerCase().includes(q) || opt.value.toLowerCase().includes(q) ? '' : 'none';
    });
  });
};

// ══════════════════════════════════════════
// THEME
// ══════════════════════════════════════════
function setTheme(t) {
  document.documentElement.setAttribute('data-theme', t);
  localStorage.setItem('mc_theme', t);
  document.querySelectorAll('.theme-btn').forEach(b =>
    b.classList.toggle('active', b.dataset.theme === t));
}
function loadTheme() {
  const t = localStorage.getItem('mc_theme') || 'claude';
  setTheme(t);
}

// ══════════════════════════════════════════
// API KEYS
// ══════════════════════════════════════════
function saveKey(p, v) {
  const hadKey = !!getKey(p);
  if (v.trim()) {
    localStorage.setItem('key_'+p, v.trim());
    document.getElementById('dot-'+p)?.classList.add('saved');
    // If this is a live provider and we just got a key, refresh models
    if (LIVE_PROVIDERS.has(p) && !hadKey) {
      const currentProvider = document.getElementById('prov-sel').value;
      if (currentProvider === p) {
        delete modelCache[p];
        populateModels(p);
      }
    }
  } else {
    localStorage.removeItem('key_'+p);
    document.getElementById('dot-'+p)?.classList.remove('saved');
  }
}
function getKey(p) { return localStorage.getItem('key_'+p) || ''; }
function loadKeys() {
  ['groq','minimax','deepinfra','openrouter'].forEach(p => {
    const k = getKey(p);
    if (k) { const el = document.getElementById('key-'+p); if(el) el.value=k; document.getElementById('dot-'+p)?.classList.add('saved'); }
  });
}

// ══════════════════════════════════════════
// SETTINGS PANEL
// ══════════════════════════════════════════
function toggleSettings() {
  const panel = document.getElementById('settings-panel');
  const btn = document.getElementById('settings-toggle');
  panel.classList.toggle('open');
  btn.classList.toggle('active');
}
function saveSettings() {
  const existing = JSON.parse(localStorage.getItem('mc_settings') || '{}');
  const s = {
    // Preserve web search settings so saveSettings() doesn't clobber them
    webSearchEnabled: existing.webSearchEnabled || false,
    webSearchProvider: existing.webSearchProvider || 'tavily',
    webSearchMode: existing.webSearchMode || 'auto',
    systemPrompt: document.getElementById('system-prompt').value,
    temperature: parseFloat(document.getElementById('temp-range').value),
    maxTokens: parseInt(document.getElementById('maxtok-range').value),
    topP: parseFloat(document.getElementById('topp-range').value),
  };
  localStorage.setItem('mc_settings', JSON.stringify(s));
}
function loadSettings() {
  try {
    const s = JSON.parse(localStorage.getItem('mc_settings') || '{}');
    if (s.systemPrompt) document.getElementById('system-prompt').value = s.systemPrompt;
    if (s.temperature != null) {
      document.getElementById('temp-range').value = s.temperature;
      document.getElementById('temp-val').textContent = s.temperature.toFixed(2);
    }
    if (s.maxTokens) {
      document.getElementById('maxtok-range').value = s.maxTokens;
      document.getElementById('maxtok-val').textContent = parseInt(s.maxTokens).toLocaleString();
    }
    if (s.topP != null) {
      document.getElementById('topp-range').value = s.topP;
      document.getElementById('topp-val').textContent = s.topP.toFixed(2);
    }
  } catch(e) {}
  loadWebSearchSettings();
}
function resetSettings() {
  document.getElementById('system-prompt').value = '';
  document.getElementById('temp-range').value = 0.7; document.getElementById('temp-val').textContent = '0.70';
  document.getElementById('maxtok-range').value = 4096; document.getElementById('maxtok-val').textContent = '4,096';
  document.getElementById('topp-range').value = 1.0; document.getElementById('topp-val').textContent = '1.00';
  // Reset web search UI
  const wsEl = document.getElementById('ws-enabled');
  if (wsEl) wsEl.checked = false;
  const cfg = document.getElementById('ws-config');
  if (cfg) cfg.style.display = 'none';
  const provEl = document.getElementById('ws-provider');
  if (provEl) provEl.value = 'tavily';
  const modeEl = document.getElementById('ws-mode');
  if (modeEl) modeEl.value = 'auto';
  updateSearchKeyRow('tavily');
  updateSearchCostNote('tavily');
  localStorage.removeItem('mc_settings');
  updateSearchIndicator();
  showToast('Settings reset to defaults');
}
function getSettings() {
  return {
    systemPrompt: document.getElementById('system-prompt').value.trim(),
    temperature: parseFloat(document.getElementById('temp-range').value),
    maxTokens: parseInt(document.getElementById('maxtok-range').value),
    topP: parseFloat(document.getElementById('topp-range').value),
  };
}

// ══════════════════════════════════════════
// RAG FILES (persistent context)
// ══════════════════════════════════════════
function handleRagDrop(e) {
  e.preventDefault();
  document.getElementById('file-drop').classList.remove('drag-over');
  handleRagFiles(e.dataTransfer.files);
}
function handleRagFiles(fileList) {
  Array.from(fileList).forEach(f => {
    if (f.size > 2 * 1024 * 1024) { showToast(`${f.name} too large (max 2MB)`,'err'); return; }
    const reader = new FileReader();
    reader.onload = e => {
      ragFiles.push({name: f.name, content: e.target.result, size: f.size});
      renderRagFileList();
      updateCtxPreview();
    };
    reader.readAsText(f);
  });
  document.getElementById('rag-input').value = '';
}
function removeRagFile(i) {
  ragFiles.splice(i, 1);
  renderRagFileList();
  updateCtxPreview();
}
function renderRagFileList() {
  const list = document.getElementById('rag-file-list');
  if (!ragFiles.length) { list.innerHTML = ''; return; }
  list.innerHTML = ragFiles.map((f,i) => `
    <div class="file-chip">
      <span class="file-chip-icon">${fileIcon(f.name)}</span>
      <span class="file-chip-name">${esc(f.name)}</span>
      <span class="file-chip-size">${fmtSize(f.size)}</span>
      <button class="file-chip-del" onclick="removeRagFile(${i})">✕</button>
    </div>`).join('');
}
function updateCtxPreview() {
  const preview = document.getElementById('ctx-preview');
  const tokEl = document.getElementById('ctx-tokens');
  if (!ragFiles.length) { preview.textContent = 'No files loaded'; tokEl.textContent = '0 tokens'; return; }
  const combined = buildRagContext();
  const approxTok = Math.ceil(combined.length / 4);
  tokEl.textContent = `~${approxTok.toLocaleString()} tokens`;
  preview.textContent = combined.slice(0, 600) + (combined.length > 600 ? '\n…' : '');
}
function buildRagContext() {
  if (!ragFiles.length) return '';
  return ragFiles.map(f =>
    `### File: ${f.name}\n\`\`\`\n${f.content.slice(0, 50000)}\n\`\`\``
  ).join('\n\n');
}

// ══════════════════════════════════════════
// INLINE ATTACH (per-message)
// ══════════════════════════════════════════
function handleFileAttach(fileList) {
  Array.from(fileList).forEach(f => {
    if (f.size > 1024 * 1024) { showToast(`${f.name} too large (max 1MB)`,'err'); return; }
    const reader = new FileReader();
    reader.onload = e => {
      attachedFiles.push({name: f.name, content: e.target.result, size: f.size});
      renderAttachedFiles();
    };
    reader.readAsText(f);
  });
  document.getElementById('attach-input').value = '';
}
function removeAttached(i) {
  attachedFiles.splice(i, 1);
  renderAttachedFiles();
}
function renderAttachedFiles() {
  const wrap = document.getElementById('attached-files');
  if (!attachedFiles.length) { wrap.classList.remove('has-files'); wrap.innerHTML = ''; return; }
  wrap.classList.add('has-files');
  wrap.innerHTML = attachedFiles.map((f,i) => `
    <div class="att-chip">
      ${fileIcon(f.name)} ${esc(f.name)} <span style="font-family:var(--font-mono);font-size:10px;color:var(--text3)">${fmtSize(f.size)}</span>
      <button class="att-chip-del" onclick="removeAttached(${i})">✕</button>
    </div>`).join('');
}

// ══════════════════════════════════════════
// PROVIDER / MODEL  — live fetch where supported
// ══════════════════════════════════════════

// Which providers support a live /models endpoint
const LIVE_PROVIDERS = new Set(['groq', 'openrouter', 'deepinfra']);

// Cache fetched model lists per provider for the session
const modelCache = {};

async function onProviderChange(forceRefresh = false) {
  const p = document.getElementById('prov-sel').value;
  updateProviderBadge(p);
  if (forceRefresh && modelCache[p]) delete modelCache[p];
  await populateModels(p);
}

async function populateModels(p) {
  const sel = document.getElementById('model-sel');
  sel.innerHTML = `<option disabled>Loading models…</option>`;

  let models = null;

  // Try live fetch if provider supports it
  const canFetchLive = LIVE_PROVIDERS.has(p) && (getKey(p) || p === 'openrouter' || p === 'deepinfra');
  if (canFetchLive) {
    if (modelCache[p]) {
      models = modelCache[p];
    } else {
      models = await fetchLiveModels(p);
      if (models) modelCache[p] = models;
    }
  }

  // Fall back to static list
  if (!models) models = PROVIDERS[p]?.models || [];

  sel.innerHTML = models.map(m =>
    `<option value="${m.id}" data-price="${m.p||''}" title="${m.id}">${m.name}</option>`
  ).join('');

  const msearch = document.getElementById('model-search');
  if (msearch) msearch.value = '';

  updatePricePill();
  sel.onchange = updatePricePill;

  // Show source indicator
  // Show source indicator
  const isLive = canFetchLive && modelCache[p];
  updateModelSourceBadge(p, models.length, isLive);
}

async function fetchLiveModels(provider) {
  const key = getKey(provider);
  // OpenRouter and DeepInfra endpoints are public, no key required to list models
  if (!key && provider !== 'openrouter' && provider !== 'deepinfra') return null;

  // ── Primary: direct provider API ──
  try {
    const url = PROVIDERS[provider].url + '/models';
    const res = await fetch(url, {
      method: 'GET',
      headers: {
        'Authorization': `Bearer ${key}`,
        'Content-Type': 'application/json',
        ...(provider === 'openrouter'
          ? {'HTTP-Referer': location.origin, 'X-Title': 'MultiChat'}
          : {})
      }
    });

    if (res.ok) {
      const json = await res.json();
      const raw = json.data || json.models || [];
      console.log(`[MultiChat] ${provider} live models: ${raw.length}`);
      return formatLiveModels(provider, raw);
    }

    // Log non-OK for debugging
    console.warn(`[MultiChat] ${provider} /models returned ${res.status}`);

  } catch(e) {
    // CORS errors throw TypeError: Failed to fetch
    // Log detail so it shows in DevTools console
    console.warn(`[MultiChat] ${provider} direct fetch failed (likely CORS):`, e.message);
  }

  // ── Fallback for Groq: fetch via OpenRouter's provider endpoint ──
  // OpenRouter has permissive CORS and lists all Groq-hosted models
  if (provider === 'groq') {
    return await fetchGroqViaOpenRouter();
  }

  return null;
}

// OpenRouter exposes GET /models with full CORS support.
// We filter for models served on Groq infrastructure using the `owned_by`
// or provider metadata, giving us an always-current Groq model list
// even when direct Groq CORS fails.
async function fetchGroqViaOpenRouter() {
  try {
    // OpenRouter /models has open CORS — no auth needed for the list
    const res = await fetch('https://openrouter.ai/api/v1/models');
    if (!res.ok) return null;
    const json = await res.json();
    const raw = json.data || [];

    // Filter to models that list "Groq" as a provider
    const groqModels = raw.filter(m => {
      const providers = m.supported_parameters?.providers ||
                        (m.per_request_limits ? Object.keys(m.per_request_limits) : []);
      // Check if 'Groq' appears in the providers array or description
      const desc = (m.description || '').toLowerCase();
      const hasGroq = Array.isArray(providers) && providers.some(p => /groq/i.test(p));
      return hasGroq;
    });

    // If the provider filter didn't work (OpenRouter schema varies),
    // fall back to fetching https://openrouter.ai/api/v1/models?provider=Groq
    if (groqModels.length === 0) {
      return await fetchGroqViaOpenRouterProvider();
    }

    console.log(`[MultiChat] Groq models via OpenRouter fallback: ${groqModels.length}`);
    // Reuse the Groq formatter but pull context from OpenRouter data
    return groqModels.map(m => ({
      id: m.id,
      name: groqDisplayNameFromOR(m),
      p: groqPrice(m.id),
    }));
  } catch(e) {
    console.warn('[MultiChat] OpenRouter Groq fallback failed:', e.message);
    return null;
  }
}

// OpenRouter supports ?provider=Groq query param on /models
async function fetchGroqViaOpenRouterProvider() {
  try {
    const res = await fetch('https://openrouter.ai/api/v1/models?provider=Groq', {
      headers: { 'HTTP-Referer': location.origin, 'X-Title': 'MultiChat' }
    });
    if (!res.ok) return null;
    const json = await res.json();
    const raw = json.data || [];
    if (!raw.length) return null;
    console.log(`[MultiChat] Groq models via OR ?provider=Groq: ${raw.length}`);
    return raw.map(m => ({
      id: m.id,
      name: groqDisplayNameFromOR(m),
      p: groqPrice(m.id),
    }));
  } catch(e) {
    return null;
  }
}

function groqDisplayNameFromOR(m) {
  // Check static list first for a curated name
  const staticMatch = (PROVIDERS.groq?.models || []).find(s => s.id === m.id);
  if (staticMatch) return staticMatch.name;
  const ctx = m.context_length ? ` (${fmtCtx(m.context_length)})` : '';
  return (m.name || m.id) + ctx;
}


function formatLiveModels(provider, raw) {
  if (provider === 'groq') {
    // Groq returns {id, object, owned_by, active, context_window, ...}
    return raw
      .filter(m => m.active !== false && m.object === 'model')
      .sort((a, b) => (b.context_window||0) - (a.context_window||0))
      .map(m => ({
        id: m.id,
        name: groqDisplayName(m),
        p: groqPrice(m.id),
      }));
  }

  if (provider === 'deepinfra') {
    return raw
      .filter(m => m.metadata && m.metadata.pricing && m.object === 'model')
      .sort((a, b) => (b.metadata?.context_length || 0) - (a.metadata?.context_length || 0))
      .map(m => {
        const inP = m.metadata.pricing.input_tokens || 0;
        const outP = m.metadata.pricing.output_tokens || 0;
        const priceStr = `$${fmtPrice(inP)}/$${fmtPrice(outP)}`;
        const ctx = m.metadata.context_length ? ` (${fmtCtx(m.metadata.context_length)})` : '';
        const rawName = m.id.split('/').pop() || '';
        return {
          id: m.id,
          name: rawName + ctx,
          p: priceStr
        };
      });
  }

  if (provider === 'openrouter') {
    // OpenRouter returns {id, name, description, pricing:{prompt,completion}, context_length, ...}
    return raw
      .sort((a, b) => {
        // Sort: free first, then by context length desc
        const aFree = parseFloat(a.pricing?.prompt||'1') === 0;
        const bFree = parseFloat(b.pricing?.prompt||'1') === 0;
        if (aFree && !bFree) return -1;
        if (!aFree && bFree) return 1;
        return (b.context_length||0) - (a.context_length||0);
      })
      .map(m => {
        const inP = parseFloat(m.pricing?.prompt || '0');
        const outP = parseFloat(m.pricing?.completion || '0');
        const isFree = inP === 0 && outP === 0;
        const priceStr = isFree
          ? 'FREE'
          : `$${fmtPrice(inP*1e6)}/$${fmtPrice(outP*1e6)}`;
        const freeTag = isFree ? '🆓 ' : '';
        const ctx = m.context_length ? ` (${fmtCtx(m.context_length)})` : '';
        return {
          id: m.id,
          name: `${freeTag}${m.name || m.id}${ctx}`,
          p: priceStr,
        };
      });
  }

  return raw.map(m => ({ id: m.id, name: m.id, p: '' }));
}

// Groom Groq model IDs into readable names
function groqDisplayName(m) {
  const id = m.id;
  const ctx = m.context_window ? ` (${fmtCtx(m.context_window)})` : '';
  // Check static list for a curated name first
  const staticMatch = (PROVIDERS.groq?.models || []).find(s => s.id === id);
  if (staticMatch) return staticMatch.name;
  // Auto-format from ID
  return id
    .replace('openai/', '').replace('moonshotai/', '').replace('meta-llama/', '')
    .replace('qwen/', '').replace(/-instruct$/i,'').replace(/-\d{4}$/,'')
    .replace(/-/g,' ').replace(/\b\w/g, c => c.toUpperCase())
    + ctx;
}

// Groq pricing lookup from static list (they don't return pricing in /models)
function groqPrice(id) {
  const m = (PROVIDERS.groq?.models || []).find(s => s.id === id);
  return m?.p || '';
}

// Format context length: 131072 → "128K", 1048576 → "1M"
function fmtCtx(n) {
  if (n >= 1000000) return (n/1000000).toFixed(0)+'M';
  if (n >= 1000) return Math.round(n/1024)+'K';
  return n;
}

// Format price per 1M tokens
function fmtPrice(n) {
  if (n === 0) return '0';
  if (n < 0.01) return n.toFixed(4);
  if (n < 1) return n.toFixed(3);
  return n.toFixed(2);
}

// Model source indicator (live vs static)
function updateModelSourceBadge(provider, count, isLive) {
  let pill = document.getElementById('model-source-pill');
  if (!pill) {
    pill = document.createElement('span');
    pill.id = 'model-source-pill';
    pill.style.cssText = `font-size:10px;font-family:var(--font-mono);padding:2px 7px;border-radius:20px;border:1px solid;cursor:pointer;white-space:nowrap;`;
    pill.title = 'Click to refresh model list';
    pill.onclick = () => refreshModels();
    document.getElementById('prov-badge').insertAdjacentElement('beforebegin', pill);
  }
  if (isLive) {
    pill.textContent = `↺ ${count} live`;
    pill.style.color = 'var(--green)';
    pill.style.background = 'rgba(46,125,94,.08)';
    pill.style.borderColor = 'rgba(46,125,94,.25)';
    pill.title = `${count} models fetched live. Click to refresh.`;
  } else if (count > 0) {
    pill.textContent = `${count} cached`;
    pill.style.color = 'var(--text3)';
    pill.style.background = 'var(--bg3)';
    pill.style.borderColor = 'var(--border)';
    pill.title = 'Using built-in model list. Add an API key to fetch live models.';
  } else {
    pill.textContent = `static`;
    pill.style.color = 'var(--text3)';
    pill.style.background = 'var(--bg3)';
    pill.style.borderColor = 'var(--border)';
  }
}

async function refreshModels() {
  const p = document.getElementById('prov-sel').value;
  delete modelCache[p]; // bust cache
  showToast(`Refreshing ${PROVIDERS[p].label} models…`);
  await populateModels(p);
}

function updateProviderBadge(p) {
  const b = document.getElementById('prov-badge');
  const info = PROVIDERS[p];
  b.textContent = info.label;
  b.className = 'prov-badge ' + info.badge;
}
function updatePricePill() {
  const sel = document.getElementById('model-sel');
  const opt = sel.options[sel.selectedIndex];
  const pr = opt?.dataset?.price || '';
  const pill = document.getElementById('price-pill');
  if (pill) pill.textContent = pr ? `in:${pr.split('/')[0]}  out:${pr.split('/')[1]}/M` : '';
}
function updateThinkLabel() {
  const show = document.getElementById('show-think').checked;
  document.getElementById('think-lbl').textContent = show ? 'Show thinking' : 'Hide thinking';
  document.querySelectorAll('.think-block').forEach(b => b.style.display = show ? 'block' : 'none');
}

// ══════════════════════════════════════════
// CHAT MANAGEMENT
// ══════════════════════════════════════════
function newChat() {
  const id = 'c' + Date.now();
  conversations[id] = {title:'New conversation', messages:[]};
  currentChatId = id;
  saveChats();
  renderChatList();
  showWelcome();
  attachedFiles = [];
  renderAttachedFiles();
  resetFooterStats();
}
function loadChat(id) {
  currentChatId = id;
  renderChatList();
  renderMessages();
  const chat = conversations[id];
  if (chat && chat.totalTokens) {
    updateFooterStats(0, 0, chat.totalTokens, chat.totalCost || 0);
    const qs = document.getElementById('query-stats');
    const sep = document.getElementById('footer-sep');
    if (qs) qs.style.display = 'none';
    if (sep) sep.style.display = 'none';
  } else {
    resetFooterStats();
  }
}
function saveChats() { try { localStorage.setItem('mc_chats', JSON.stringify(conversations)); } catch(e) {} }
function loadChats() {
  try { const s = localStorage.getItem('mc_chats'); if(s) conversations = JSON.parse(s); } catch(e) {}
  renderChatList();
}
function renderChatList() {
  document.getElementById('chat-list').innerHTML =
    Object.keys(conversations).reverse().map(id =>
      `<div class="chat-item ${id===currentChatId?'active':''}" onclick="loadChat('${id}')">${esc(conversations[id].title)}</div>`
    ).join('');
}

// ══════════════════════════════════════════
// RENDER MESSAGES
// ══════════════════════════════════════════
function showWelcome() {
  document.getElementById('messages').innerHTML = `
    <div id="welcome">
      <div class="wlc-icon">◆</div>
      <div class="wlc-title">MultiChat</div>
      <div class="wlc-sub">Chat with frontier models via Groq, MiniMax, DeepInfra & OpenRouter. Upload files, set system prompts, tune temperature.</div>
      <div class="suggs">
        <div class="sug-card" onclick="useSug('Explain MoE vs dense LLM architectures and their cost/quality trade-offs')">
          <div class="sug-icon">🧠</div><div class="sug-title">MoE vs Dense</div><div class="sug-desc">Architecture trade-offs</div>
        </div>
        <div class="sug-card" onclick="useSug('Write a PySpark function to calculate bond total return index from a Delta table')">
          <div class="sug-icon">⚡</div><div class="sug-title">PySpark / Databricks</div><div class="sug-desc">Bond index calculation</div>
        </div>
        <div class="sug-card" onclick="useSug('Compare DeepSeek V3.2, Kimi K2, and MiniMax M2.5 for financial data analysis')">
          <div class="sug-icon">📊</div><div class="sug-title">Model Comparison</div><div class="sug-desc">Chinese LLMs for finance</div>
        </div>
        <div class="sug-card" onclick="useSug('Explain the S&amp;P GSCI commodity index roll return methodology')">
          <div class="sug-icon">🏦</div><div class="sug-title">GSCI Methodology</div><div class="sug-desc">Roll return calculation</div>
        </div>
      </div>
    </div>`;
}
function providerFromModel(modelId) {
  if (!modelId) return 'groq';
  for (const [pid, pdata] of Object.entries(PROVIDERS)) {
    if (pdata.models.some(m => m.id === modelId)) return pid;
  }
  // fallback heuristic
  if (modelId.includes('minimax') || modelId.includes('MiniMax')) return 'minimax';
  if (modelId.includes('deepseek') || modelId.includes('kimi') || modelId.includes('Kimi') ||
      modelId.includes('qwen') || modelId.includes('Qwen') || modelId.includes('glm') ||
      modelId.includes('GLM') || modelId.includes('nvidia') || modelId.includes('llama-4') ||
      modelId.includes('stepfun') || modelId.includes('mimo') || modelId.includes('gemini') ||
      modelId.includes('anthropic') || modelId.includes('openai/gpt')) return 'deepinfra';
  return 'groq';
}

function providerIcon(pid) {
  return {groq:'⚡', minimax:'🔷', deepinfra:'🔵', openrouter:'🔀'}[pid] || '🤖';
}

function shortModelName(modelId) {
  if (!modelId) return '';
  // Find display name from PROVIDERS
  for (const pdata of Object.values(PROVIDERS)) {
    const found = pdata.models.find(m => m.id === modelId);
    if (found) {
      // Strip price/emoji suffixes for cleaner display
      return found.name.replace(/\s*[★🆓🏆]\s*/g,'').replace(/\s*\(.*?\)\s*/g,'').trim();
    }
  }
  // Fallback: clean up the raw ID
  return modelId.split('/').pop().replace(/-instruct.*|Instruct.*/i,'').slice(0,36);
}

function renderMessages() {
  const chat = currentChatId && conversations[currentChatId];
  if (!chat || !chat.messages.length) { showWelcome(); return; }
  const msgs = document.getElementById('messages');
  let lastModel = null;
  let html = '';
  chat.messages.forEach((m, i, arr) => {
    // Insert model-switch divider when AI model changes
    if (m.role === 'assistant' && m.model && m.model !== lastModel && lastModel !== null) {
      const pid = providerFromModel(m.model);
      html += `<div class="model-switch-divider">
        <span class="model-switch-label">${providerIcon(pid)} Switched to ${shortModelName(m.model)}</span>
      </div>`;
    }
    if (m.role === 'assistant' && m.model) lastModel = m.model;
    html += buildMsgHTML(m, i);
    if (i < arr.length - 1) html += '<div class="msg-sep"></div>';
  });
  msgs.innerHTML = html;
  msgs.scrollTop = msgs.scrollHeight;
}
function renderMsgsFromArr(messages) {
  const msgs = document.getElementById('messages');
  if (!messages.length) { showWelcome(); return; }
  let lastModel = null;
  let html = '';
  messages.forEach((m, i, arr) => {
    if (m.role === 'assistant' && m.model && m.model !== lastModel && lastModel !== null) {
      const pid = providerFromModel(m.model);
      html += `<div class="model-switch-divider">
        <span class="model-switch-label">${providerIcon(pid)} Switched to ${shortModelName(m.model)}</span>
      </div>`;
    }
    if (m.role === 'assistant' && m.model) lastModel = m.model;
    html += buildMsgHTML(m, i);
    if (i < arr.length - 1) html += '<div class="msg-sep"></div>';
  });
  msgs.innerHTML = html;
  msgs.scrollTop = msgs.scrollHeight;
}
function buildMsgHTML(m, msgIndex) {
  const isUser = m.role === 'user';
  const showThink = document.getElementById('show-think').checked;
  let thinkHTML = '';
  if (!isUser && m.thinking) {
    thinkHTML = `<div class="think-block" style="display:${showThink?'block':'none'}">
      <div class="think-hdr" onclick="toggleThink(this)">
        <span class="think-chev">▶</span><span>Model thinking</span>
        <span style="margin-left:auto;font-size:11px;">${wordCount(m.thinking)} words</span>
      </div>
      <div class="think-body">${esc(m.thinking)}</div>
    </div>`;
  }
  const searchHTML = (!isUser && m.searchMeta?.results?.length) ? renderSearchPanel(m.searchMeta) : '';
  let attachHTML = '';
  if (isUser && m.attachments?.length) {
    attachHTML = `<div style="display:flex;flex-wrap:wrap;gap:5px;margin-bottom:6px;">${
      m.attachments.map(a => `<div class="att-chip">${fileIcon(a.name)} ${esc(a.name)} <span style="font-family:var(--font-mono);font-size:10px;color:var(--text3)">${fmtSize(a.size)}</span></div>`).join('')
    }</div>`;
  }
  const av = isUser ? `<div class="avatar av-user">R</div>` : `<div class="avatar av-ai">◆</div>`;

  let modelBadgeHTML = '';
  if (!isUser && m.model) {
    const pid = m.provider || providerFromModel(m.model);
    const icon = providerIcon(pid);
    const label = shortModelName(m.model);
    modelBadgeHTML = `<span class="model-badge mb-${pid}" title="${esc(m.model)}">
      <span class="model-badge-icon">${icon}</span>${esc(label)}
    </span>`;
  }

  // Edit button for user messages
  const editBtn = isUser && msgIndex !== undefined
    ? `<button class="msg-edit-btn" onclick="startEditMessage(${msgIndex})" title="Edit and resubmit">✏️</button>`
    : '';
  const copyPill = !isUser && msgIndex !== undefined
    ? `<button class="msg-copy-pill" onclick="copyMsg(${msgIndex})"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>Copy</button>`
    : '';

  const name = isUser
    ? `<span class="msg-name">You</span>${editBtn}`
    : `<span class="msg-name">MultiChat</span>${modelBadgeHTML}`;

  return `<div class="msg-row"><div class="msg-inner">${av}<div class="msg-body">
    <div class="msg-meta">${name}</div>
    ${attachHTML}${searchHTML}${thinkHTML}
    <div class="msg-text">${fmtText(m.content||'', m.searchMeta)}</div>
    ${copyPill}
  </div></div></div>`;
}
function toggleThink(hdr) {
  hdr.querySelector('.think-chev').classList.toggle('open');
  hdr.nextElementSibling.classList.toggle('vis');
}

// ══════════════════════════════════════════
// EDIT PREVIOUS MESSAGE
// ══════════════════════════════════════════
function startEditMessage(msgIndex) {
  if (isStreaming) { showToast('Wait for the current response to finish','err'); return; }
  const chat = currentChatId && conversations[currentChatId];
  if (!chat) return;
  const msg = chat.messages[msgIndex];
  if (!msg || msg.role !== 'user') return;

  // Load the message text into the input
  const inp = document.getElementById('chat-input');
  inp.value = msg.content || '';
  autoResize(inp);
  inp.focus();
  inp.selectionStart = inp.selectionEnd = inp.value.length;

  // Truncate the conversation: remove this message and everything after it
  chat.messages.splice(msgIndex);
  saveChats();
  renderMessages();

  showToast('✏️ Editing — press send to resubmit');
}

// ══════════════════════════════════════════
// SEND MESSAGE
// ══════════════════════════════════════════
async function sendMessage() {
  const input = document.getElementById('chat-input');
  const text = input.value.trim();
  if (!text && !attachedFiles.length) return;
  if (isStreaming) return;

  const provider = document.getElementById('prov-sel').value;
  const model = document.getElementById('model-sel').value;
  const apiKey = getKey(provider);
  if (!apiKey) { showToast(`No API key for ${PROVIDERS[provider].label} — add it in sidebar`,'err'); return; }

  if (!currentChatId) {
    const id = 'c' + Date.now();
    conversations[id] = {title: (text||attachedFiles[0]?.name||'Chat').slice(0,42), messages:[]};
    currentChatId = id;
  }
  const chat = conversations[currentChatId];
  if (!chat.messages.length) chat.title = (text||attachedFiles[0]?.name||'Chat').slice(0,42) + ((text?.length||0)>42?'…':'');

  // Build user message including any inline attachments
  const userMsg = {role:'user', content: text, attachments: attachedFiles.length ? [...attachedFiles] : undefined};
  chat.messages.push(userMsg);

  const snapAttach = [...attachedFiles];
  attachedFiles = [];
  renderAttachedFiles();
  input.value = '';
  autoResize(input);
  updateTokCount('');
  saveChats();
  renderChatList();
  renderMsgsFromArr(chat.messages);
  appendTypingIndicator();

  isStreaming = true;
  document.getElementById('send-btn').disabled = true;

  const settings = getSettings();

  // ── Pre-flight web search (two-phase: LLM plans queries → parallel search) ──
  lastSearchMeta = null;
  const wss = JSON.parse(localStorage.getItem('mc_settings') || '{}');
  if (wss.webSearchEnabled) {
    const searchProvider = wss.webSearchProvider || 'tavily';
    try {
      // Phase 1: LLM plans search queries
      setTypingSearchStatus('Planning search…');
      const plan = await planSearchQueries(text, provider, model, apiKey);

      let queriesToRun = plan.search_queries;
      const shouldSearch = wss.webSearchMode === 'always'
        ? (queriesToRun.length > 0 || (queriesToRun = [detectSearchNeeded(text).query || text.slice(0,80)], true))
        : (wss.webSearchMode === 'auto' && plan.needs_search && queriesToRun.length > 0);

      if (shouldSearch) {
        // Phase 2: Execute all queries in parallel
        const queryLabel = queriesToRun.length > 1
          ? queriesToRun.map(q => q.slice(0,30)).join(' · ')
          : queriesToRun[0];
        setTypingSearchStatus(queryLabel);

        const searchResults = await Promise.all(
          queriesToRun.map(q => executeSearch(q, searchProvider).then(items => ({ query: q, items })).catch(e => ({ query: q, items: [], error: e.message })))
        );

        const succeeded = searchResults.filter(r => r.items?.length > 0);
        const failed    = searchResults.filter(r => r.error);

        if (succeeded.length > 0) {
          // Flatten all items for the panel, preserve query grouping for context
          const allItems = succeeded.flatMap(r => r.items);
          lastSearchMeta = { queries: queriesToRun, provider: searchProvider, results: allItems, grouped: succeeded };
          const totalSrc = allItems.length;
          const provLabel = SEARCH_PROVIDERS[searchProvider]?.label || searchProvider;
          showToast(`🔍 ${totalSrc} source${totalSrc===1?'':'s'} via ${provLabel} (${queriesToRun.length} quer${queriesToRun.length===1?'y':'ies'})`);
        } else {
          showToast('🔍 Search returned no results — model will answer from training data');
        }
        if (failed.length > 0) {
          showToast(`🔍 ${failed.length} quer${failed.length===1?'y':'ies'} failed: ${failed[0].error}`, 'err');
        }
      }
    } catch(searchErr) {
      showToast(`🔍 Search error: ${searchErr.message}`, 'err');
    }
    setTypingSearchStatus(null);
  }

  // Build API messages (with search context injected if available)
  const searchContext = lastSearchMeta
    ? formatSearchContext(lastSearchMeta.queries, lastSearchMeta.grouped || lastSearchMeta.results)
    : null;
  const apiMessages = buildApiMessages(chat.messages, snapAttach, settings.systemPrompt, searchContext);

  const payload = {
    model,
    messages: apiMessages,
    stream: true,
    max_tokens: settings.maxTokens,
    temperature: settings.temperature,
    top_p: settings.topP,
  };
  if (provider === 'minimax') payload.extra_body = {reasoning_split: true};
  // For OpenRouter: prefer direct provider over Bedrock/Vertex to avoid their PII Guardrails
  if (provider === 'openrouter') {
    payload.transforms = [];
    payload.provider = { ignore: ['Amazon Bedrock'] };
  }

  try {
    const resp = await fetch(PROVIDERS[provider].url + '/chat/completions', {
      method:'POST',
      headers:{
        'Content-Type':'application/json',
        'Authorization':`Bearer ${apiKey}`
      },
      body: JSON.stringify(payload)
    });

    if (!resp.ok) {
      const err = await resp.json().catch(()=>({}));
      throw new Error(err?.error?.message || `HTTP ${resp.status}`);
    }

    removeTypingIndicator();
    const aiMsg = {role:'assistant', content:'', thinking:'', model, provider};
    chat.messages.push(aiMsg);
    appendStreamRow(aiMsg);

    const reader = resp.body.getReader();
    const dec = new TextDecoder();
    let buf = '';
    let lastUsage = null;

    while(true) {
      const {done, value} = await reader.read();
      if(done) break;
      buf += dec.decode(value, {stream:true});
      const lines = buf.split('\n'); buf = lines.pop();
      for(const line of lines) {
        if(!line.startsWith('data: ')) continue;
        const data = line.slice(6).trim();
        if(data==='[DONE]') continue;
        try {
          const j = JSON.parse(data);
          if(j.usage) lastUsage = j.usage;
          const d = j.choices?.[0]?.delta;
          if(!d) continue;
          const thDelta = d.reasoning_content || d.thinking || '';
          const txtDelta = d.content || '';
          if(thDelta) aiMsg.thinking += thDelta;
          if(txtDelta) aiMsg.content += txtDelta;
          updateStreamRow(aiMsg);
        } catch(e) {}
      }
    }

    aiMsg.content = stripThink(aiMsg.content);
    aiMsg.thinking = (aiMsg.thinking + extractThink(aiMsg.content)).trim();
    if (lastSearchMeta) aiMsg.searchMeta = lastSearchMeta;
    lastSearchMeta = null;

    if (lastUsage) {
      const sel = document.getElementById('model-sel');
      const priceStr = sel.options[sel.selectedIndex]?.dataset?.price || '';
      const promptTok = lastUsage.prompt_tokens || 0;
      const compTok = lastUsage.completion_tokens || 0;
      let queryCost = 0;
      if (priceStr && priceStr !== 'FREE' && priceStr !== '$0/$0') {
        const parts = priceStr.replace(/\$/g, '').split('/');
        const inP = parseFloat(parts[0]) || 0;
        const outP = parseFloat(parts[1]) || 0;
        queryCost = (promptTok * inP / 1e6) + (compTok * outP / 1e6);
      }
      aiMsg.usage = {prompt_tokens: promptTok, completion_tokens: compTok, cost: queryCost};
      chat.totalTokens = (chat.totalTokens || 0) + promptTok + compTok;
      chat.totalCost = (chat.totalCost || 0) + queryCost;
      updateFooterStats(promptTok + compTok, queryCost, chat.totalTokens, chat.totalCost);
    }

    saveChats();
    renderMessages();

  } catch(err) {
    removeTypingIndicator();
    showToast('❌ ' + (err.message||'Request failed'),'err');
    chat.messages.pop();
    renderMessages();
  } finally {
    isStreaming = false;
    document.getElementById('send-btn').disabled = false;
  }
}

function buildApiMessages(chatMessages, snapAttach, systemPrompt, searchContext = null) {
  const ragCtx = buildRagContext();
  const isReasoner = /r1|qwq|think|reason|m2|gpt-oss|qwen3|glm/i.test(document.getElementById('model-sel').value);
  const noPlaceholders = `Never replace real names, places, or entities with placeholders like [PERSON_NAME], [ADDRESS], [LOCATION], or similar. Always use the actual names as provided in the user message or search context.`;
  const defaultSys = isReasoner
    ? `You are a helpful, knowledgeable assistant. Today's date is ${new Date().toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'})}. ${noPlaceholders} Think carefully but output ONLY your clean final answer — no <think> tags, no reasoning prefixes. Use clear markdown formatting.`
    : `You are a helpful, knowledgeable assistant. Today's date is ${new Date().toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'})}. ${noPlaceholders} Use clear markdown formatting.`;

  // Always start with the role/identity instruction, then append supplementary context.
  // Using || defaultSys was wrong: when searchContext existed without a user systemPrompt,
  // sysContent was truthy (just raw results), so defaultSys was silently dropped and the
  // model received no role identity, causing it to ignore the injected search data.
  const sysParts = [systemPrompt || defaultSys];
  if (ragCtx) sysParts.push(`You have been provided the following files as context. Use them to answer questions:\n\n${ragCtx}`);
  if (searchContext) sysParts.push(searchContext);
  const finalSys = sysParts.join('\n\n');

  const apiMsgs = [{role:'system', content: finalSys}];

  chatMessages.forEach((m, idx) => {
    const isLast = idx === chatMessages.length - 1;
    let content = m.content || '';
    if (m.role === 'user') {
      // Re-inject search context from the assistant reply that followed this message
      if (!isLast) {
        const nextMsg = chatMessages[idx + 1];
        if (nextMsg?.role === 'assistant' && nextMsg?.searchMeta?.results?.length) {
          const sm = nextMsg.searchMeta;
          const grouped = sm.grouped || sm.results.map(r => ({query: sm.query || '', items: [r]}));
          const histCtx = formatSearchContext(sm.queries || (sm.query ? [sm.query] : []), grouped);
          if (histCtx) content = content + '\n\n' + histCtx;
        }
      }
      // Inject inline attachments for last user message
      if (isLast && snapAttach.length) {
        const attachCtx = snapAttach.map(f =>
          `\n\n### Attached: ${f.name}\n\`\`\`\n${f.content.slice(0,20000)}\n\`\`\``
        ).join('');
        content = content + attachCtx;
      } else if (m.attachments?.length && !isLast) {
        const names = m.attachments.map(a=>a.name).join(', ');
        content = content + (content ? '\n' : '') + `[Attached files: ${names}]`;
      }
    }
    apiMsgs.push({role: m.role, content});
  });

  return apiMsgs;
}

// ══════════════════════════════════════════
// STREAMING DOM
// ══════════════════════════════════════════
function appendTypingIndicator() {
  const msgs = document.getElementById('messages');
  const row = document.createElement('div');
  row.id = 'typing-row'; row.className = 'msg-row';
  row.innerHTML = `<div class="msg-inner"><div class="avatar av-ai">◆</div><div class="msg-body">
    <div class="msg-meta"><span class="msg-name">MultiChat</span></div>
    <div class="typing-ind"><div class="tdot"></div><div class="tdot"></div><div class="tdot"></div></div>
  </div></div>`;
  msgs.appendChild(row);
  msgs.scrollTop = msgs.scrollHeight;
}
function removeTypingIndicator() { document.getElementById('typing-row')?.remove(); }

let streamTextEl = null, streamThinkEl = null, streamThinkBlock = null;
function appendStreamRow(msg) {
  const msgs = document.getElementById('messages');
  const row = document.createElement('div');
  row.id = 'stream-row'; row.className = 'msg-row';
  const showThink = document.getElementById('show-think').checked;
  const pid = msg.provider || providerFromModel(msg.model);
  const icon = providerIcon(pid);
  const label = shortModelName(msg.model);
  const searchHTML = lastSearchMeta ? renderSearchPanel(lastSearchMeta) : '';
  row.innerHTML = `<div class="msg-inner"><div class="avatar av-ai">◆</div><div class="msg-body">
    <div class="msg-meta">
      <span class="msg-name">MultiChat</span>
      <span class="model-badge mb-${pid}" title="${esc(msg.model)}">
        <span class="model-badge-icon">${icon}</span>${esc(label)}
      </span>
    </div>
    ${searchHTML}
    <div id="sth-block" class="think-block" style="display:none;">
      <div class="think-hdr" onclick="toggleThink(this)">
        <span class="think-chev">▶</span><span>Model thinking</span>
        <span id="sth-wc" style="margin-left:auto;font-size:11px;"></span>
      </div>
      <div class="think-body vis" id="sth-body"></div>
    </div>
    <div class="msg-text" id="sth-text"></div>
  </div></div>`;
  msgs.appendChild(row);
  streamTextEl = document.getElementById('sth-text');
  streamThinkEl = document.getElementById('sth-body');
  streamThinkBlock = document.getElementById('sth-block');
  msgs.scrollTop = msgs.scrollHeight;
}
function updateStreamRow(msg) {
  if (!streamTextEl) return;
  const showThink = document.getElementById('show-think').checked;
  if (msg.thinking && streamThinkBlock) {
    streamThinkBlock.style.display = showThink ? 'block' : 'none';
    if (streamThinkEl) { streamThinkEl.textContent = msg.thinking; }
    const wc = document.getElementById('sth-wc');
    if (wc) wc.textContent = wordCount(msg.thinking) + ' words';
  }
  streamTextEl.innerHTML = fmtText(stripThink(msg.content));
  document.getElementById('messages').scrollTop = 99999;
}

// ══════════════════════════════════════════
// THINKING HELPERS
// ══════════════════════════════════════════
function extractThink(t) {
  const m=[]; t.replace(/<think(?:ing)?>([\s\S]*?)<\/think(?:ing)?>/gi,(_,x)=>m.push(x)); return m.join('\n');
}
function stripThink(t) {
  return t.replace(/<think(?:ing)?>([\s\S]*?)<\/think(?:ing)?>/gi,'').replace(/^[\s\n]+/,'').trim();
}

// ══════════════════════════════════════════
// TEXT FORMAT (markdown-lite)
// ══════════════════════════════════════════
function fmtText(text, searchMeta) {
  if (!text) return '';
  text = text.replace(/```(\w*)\n?([\s\S]*?)```/g, (_,l,c) => `<pre><code>${esc(c.trim())}</code></pre>`);
  text = text.replace(/`([^`\n]+)`/g, (_,c) => `<code>${esc(c)}</code>`);
  text = text.replace(/^### (.+)$/gm,'<h3>$1</h3>');
  text = text.replace(/^## (.+)$/gm,'<h2>$1</h2>');
  text = text.replace(/^# (.+)$/gm,'<h1>$1</h1>');
  text = text.replace(/\*\*\*(.+?)\*\*\*/g,'<strong><em>$1</em></strong>');
  text = text.replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>');
  text = text.replace(/\*(.+?)\*/g,'<em>$1</em>');
  text = text.replace(/^> (.+)$/gm,'<blockquote>$1</blockquote>');
  text = text.replace(/((?:^[-*] .+\n?)+)/gm, m => {
    const items = m.trim().split('\n').map(l=>`<li>${l.replace(/^[-*] /,'')}</li>`).join('');
    return `<ul>${items}</ul>`;
  });
  text = text.replace(/((?:^\d+\. .+\n?)+)/gm, m => {
    const items = m.trim().split('\n').map(l=>`<li>${l.replace(/^\d+\. /,'')}</li>`).join('');
    return `<ol>${items}</ol>`;
  });
  if (searchMeta?.results?.length) {
    const results = searchMeta.results;
    text = text.replace(/\[(\d+)\]/g, (match, n) => {
      const r = results[parseInt(n) - 1];
      return r?.url
        ? `<a href="${esc(r.url)}" target="_blank" rel="noopener noreferrer" class="citation-link">[${n}]</a>`
        : match;
    });
  }
  text = text.replace(/\n/g,'<br>');
  return text;
}

// ══════════════════════════════════════════
// PWA + MOBILE
// ══════════════════════════════════════════

// Service Worker registration
if ('serviceWorker' in navigator) {
  window.addEventListener('load', () => {
    navigator.serviceWorker.register('./sw.js')
      .then(r => console.log('SW registered:', r.scope))
      .catch(e => console.warn('SW failed:', e));
  });
}

// PWA install prompt
let deferredInstall = null;
window.addEventListener('beforeinstallprompt', e => {
  e.preventDefault();
  deferredInstall = e;
  const banner = document.getElementById('install-banner');
  if (banner && !localStorage.getItem('mc_pwa_dismissed')) {
    banner.style.display = 'flex';
  }
});
function installPWA() {
  if (!deferredInstall) return;
  deferredInstall.prompt();
  deferredInstall.userChoice.then(r => {
    if (r.outcome === 'accepted') {
      document.getElementById('install-banner').style.display = 'none';
      localStorage.setItem('mc_pwa_dismissed', '1');
    }
    deferredInstall = null;
  });
}
window.addEventListener('appinstalled', () => {
  document.getElementById('install-banner').style.display = 'none';
  localStorage.setItem('mc_pwa_dismissed', '1');
});

// Sidebar toggle for mobile
function toggleSidebar() {
  const sb = document.getElementById('sidebar');
  const ov = document.getElementById('sidebar-overlay');
  sb.classList.toggle('open');
  ov.classList.toggle('show');
}
function closeSidebar() {
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('sidebar-overlay').classList.remove('show');
}
// Close sidebar when a chat is selected on mobile
const _origLoadChat = loadChat;
// patch loadChat to close sidebar on mobile
window.loadChat = function(id) {
  _origLoadChat(id);
  if (window.innerWidth <= 700) closeSidebar();
};
// Close sidebar when new chat pressed on mobile
const _origNewChat = newChat;
window.newChat = function() {
  _origNewChat();
  if (window.innerWidth <= 700) closeSidebar();
};

// Sync theme-color meta tag with active theme
const THEME_COLORS = {
  claude:'#c96b2f', chatgpt:'#212121', gemini:'#0f0f10',
  dark:'#0d0d0d', minimal:'#ffffff'
};
const _origSetTheme = setTheme;
window.setTheme = function(t) {
  _origSetTheme(t);
  const meta = document.getElementById('theme-meta');
  if (meta) meta.content = THEME_COLORS[t] || '#c96b2f';
  // Also update manifest theme_color dynamically
  document.querySelector('meta[name="theme-color"]').setAttribute('content', THEME_COLORS[t] || '#c96b2f');
};

// Handle ?new=1 shortcut (PWA shortcut link)
if (new URLSearchParams(location.search).get('new') === '1') {
  window.addEventListener('load', () => setTimeout(newChat, 200));
}

// Prevent pull-to-refresh on the messages area (common mobile annoyance)
document.addEventListener('touchmove', e => {
  const msgs = document.getElementById('messages');
  if (msgs && msgs.contains(e.target) && msgs.scrollTop > 0) return;
}, { passive: false });

function copyMsg(msgIndex) {
  const chat = currentChatId && conversations[currentChatId];
  if (!chat) return;
  const msg = chat.messages[msgIndex];
  if (!msg) return;
  navigator.clipboard.writeText(msg.content || '').then(() => showToast('Copied to clipboard'));
}
function updateFooterStats(queryTok, queryCost, totalTok, totalCost) {
  const qs = document.getElementById('query-stats');
  const cs = document.getElementById('conv-stats');
  const sep = document.getElementById('footer-sep');
  if (!qs || !cs || !sep) return;
  if (queryTok > 0) {
    qs.textContent = `${queryTok.toLocaleString()} tok · $${queryCost.toFixed(4)}`;
    qs.style.display = '';
    sep.style.display = '';
  }
  cs.textContent = `Σ ${totalTok.toLocaleString()} tok · $${totalCost.toFixed(4)}`;
  cs.style.display = '';
}
function resetFooterStats() {
  ['query-stats','footer-sep','conv-stats'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.style.display = 'none';
  });
}
function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function wordCount(t) { return (t||'').trim().split(/\s+/).filter(Boolean).length; }
function fmtSize(b) { return b>1024*1024?(b/1024/1024).toFixed(1)+'MB':b>1024?(b/1024).toFixed(0)+'KB':b+'B'; }
function fileIcon(name) {
  const ext = name.split('.').pop().toLowerCase();
  const map = {py:'🐍',js:'📜',ts:'📘',html:'🌐',css:'🎨',json:'📋',csv:'📊',md:'📝',txt:'📄',pdf:'📕',xml:'🔧',yaml:'⚙',yml:'⚙'};
  return map[ext] || '📄';
}
function handleKey(e) {
  // Enter always inserts a newline — submit only via the send button
  updateTokCount(document.getElementById('chat-input').value);
}
function autoResize(el) { el.style.height='auto'; el.style.height=Math.min(el.scrollHeight,200)+'px'; updateTokCount(el.value); }
function updateTokCount(t) { document.getElementById('tok-count').textContent=`~${Math.ceil((t||'').length/4)} tokens`; }
function useSug(t) { const inp=document.getElementById('chat-input'); inp.value=t; autoResize(inp); sendMessage(); }
function showToast(msg, type='') {
  const t = document.getElementById('toast');
  t.textContent = msg; t.className = type==='err'?'err':'';
  t.style.display='block';
  setTimeout(()=>t.style.display='none', 4500);
}
</script>
</body>
</html>
